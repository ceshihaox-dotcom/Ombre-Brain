# ============================================================
# Ombre-Brain 环境变量示例
# 复制为 .env 文件后填入你的实际值
# 云部署 (Render/Railway/etc) 在 dashboard 里配置同样的变量
# ============================================================

# ─── 必填: LLM 模型配置 ───────────────────────────────────────

# LLM API key (DeepSeek / Gemini / Claude / OpenAI 等任意 OpenAI 兼容 API)
OMBRE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM API base URL
# DeepSeek:    https://api.deepseek.com/v1
# Gemini:      https://generativelanguage.googleapis.com/v1beta/openai/
# Claude:      https://api.anthropic.com/v1/
# OpenAI:      https://api.openai.com/v1
# 硅基流动:    https://api.siliconflow.cn/v1
# DashScope:   https://dashscope.aliyuncs.com/compatible-mode/v1
OMBRE_BASE_URL=https://api.deepseek.com/v1

# 模型名称 (跟你选的 base URL 对应)
# 例: deepseek-chat / gemini-2.5-flash / claude-haiku-4-5 / gpt-4o-mini
OMBRE_MODEL=deepseek-chat


# ─── 可选: Embedding 模型 (独立配置, 给"全库相似" / 主动浮现等功能用) ───
# 不配的话, 跟 OMBRE_API_KEY 一样的 key, 但 base URL 用下面的
# 强烈推荐 gemini-embedding-001 (3072 维, 与默认一致; 换模型在 config.yaml 的 embedding.model 改)

OMBRE_EMBED_API_KEY=
OMBRE_EMBED_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# ─── 可选: Docker 部署的宿主机挂载目录 (docker-compose.yml 用) ───
# 把记忆数据存到你指定的宿主机目录(如 Obsidian Vault); 不设则用项目内 ./buckets
# OMBRE_HOST_VAULT_DIR=/path/to/your/Obsidian Vault/Ombre Brain


# ─── 必填: 数据存储路径 ──────────────────────────────────────

# 记忆桶存储目录 (绝对路径推荐, 云部署用持久盘挂载点)
# 本地开发:     ./buckets
# Render:       /opt/render/project/src/buckets
# Railway:      /app/data/buckets (需挂载 volume)
OMBRE_BUCKETS_DIR=./buckets


# ─── 必填: 传输模式 ─────────────────────────────────────────

# stdio:           本地用 (Claude Desktop / Cursor / VSCode 等 MCP 客户端)
# streamable-http: 云部署 / 远程访问 (HTTP API + 网页前端)
OMBRE_TRANSPORT=streamable-http


# ─── 可选: 管理员 token (保护写操作) ────────────────────────
# 不设的话所有 API 都开放访问, 公网部署强烈建议设
OMBRE_ADMIN_TOKEN=


# ─── 可选: 自动备份 (强烈建议云部署用户配) ────────────────
# 配上 GitHub Actions 每天自动推 buckets/ 到你的私人 git 仓库
# 我之前因为持久盘事故丢过 7 天数据, 这套是长期解药

# 私人 GitHub 仓库 (建一个空的, 设成 private)
# 例: github.com/yourname/my-ombre-backup
OMBRE_BACKUP_REPO=

# GitHub Personal Access Token (https://github.com/settings/tokens)
# 权限只需 repo (private 仓库写入)
OMBRE_BACKUP_TOKEN=

# 备份 commit 用的用户名 + email (可选)
OMBRE_BACKUP_USER=ombre-bot
